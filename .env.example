# ================================================
# CI4 Production Grade Kit — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ================================================

# App
CI_ENVIRONMENT=development
APP_NAME="CI4 PGK"
APP_VERSION=1.0.0
app.baseURL='http://localhost:8080/'

# Database
database.default.hostname=localhost
database.default.port=3306
database.default.database=ci4pgk
database.default.username=root
database.default.password=
database.default.DBDriver=MySQLi
database.default.DBPrefix=

# CORS
# Set CORS_ALLOWED_ORIGINS to your frontend domain in production.
# Example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
# Wildcard (*) is fine for local development only.
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Tus-Resumable,Upload-Length,Upload-Metadata,Upload-Offset

# Logging
logger.threshold=4

# Shield / Auth
AUTH_ENABLE_SESSION=true
AUTH_ENABLE_MAGIC_LINK=false

# SSO (Single Sign-On)
# Set SSO_ENABLED=true to activate JWT-based SSO layer.
# SSO_PUBLIC_KEY  — used by Resource Server to verify incoming tokens.
# SSO_PRIVATE_KEY — used ONLY by SSO Server to sign tokens. NEVER commit the actual value.
# SSO_TOKEN_TTL   — token lifetime in seconds (default: 3600 = 1 hour).
SSO_ENABLED=false
SSO_PUBLIC_KEY=
SSO_PRIVATE_KEY=
SSO_TOKEN_TTL=3600

# Storage / S3
# Uncomment and fill in these values when using the optional S3Driver.
# S3_BUCKET=
# S3_REGION=
# S3_KEY=
# S3_SECRET=
# S3_ENDPOINT=

# TUS Chunked Upload (optional)
# Uncomment and configure for chunked/resumable upload via TUS protocol:
#   composer require ankitpokhrel/tus-php
# TUS_UPLOAD_DIR=writable/uploads/tus
# TUS_MAX_SIZE=1073741824
# TUS_EXPIRY_HOURS=24

# WebSocket (optional v4.0)
# Set WS_ENABLED=true to activate the WebSocket server and publisher.
# Requires: composer require cboden/ratchet
# WARNING: WS_HOST must be 127.0.0.1 in production — changing it exposes the
#          internal HTTP publish endpoint (WS_HTTP_PORT) to the network.
# WS_ENABLED=false
# WS_HOST=127.0.0.1
# WS_PORT=8081            # WebSocket client connections
# WS_HTTP_PORT=8082       # Internal HTTP publish (CI4 → Ratchet)
# WS_SECRET=
# WS_MAX_PAYLOAD=131072
# WS_PUBLISH_TIMEOUT=0.5
# WS_RATE_LIMIT=20           # Max messages per second per WebSocket connection
# WS_MAX_CHANNELS=10000      # Max unique channel names before new subscriptions are rejected

# Security (uncomment in production)
# app.forceGlobalSecureRequests=true
# app.CSPEnabled=true

# Encryption key (required if using encrypted cookies/session)
# encryption.key=

# Session (default: FileHandler, fine for most cases)
# session.driver='CodeIgniter\Session\Handlers\DatabaseHandler'
# session.savePath=ci_sessions
